generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Purchase {
  id         Int         @id @default(autoincrement())
  date       DateTime
  itemName   String
  price      Int
  grams      Int
  source     String
  purpose    String?
  category   String      @default("ingredient")
  createdAt  DateTime    @default(now())
  ingredient Ingredient?
}

model Ingredient {
  id           Int            @id @default(autoincrement())
  name         String         @unique
  purchaseId   Int            @unique
  purchase     Purchase       @relation(fields: [purchaseId], references: [id])
  totalGrams   Int
  usedGrams    Int            @default(0)
  expiryDate   DateTime?
  storageNote  String?
  usageHistory UsageHistory[]
  createdAt    DateTime       @default(now())
}

model UsageHistory {
  id           Int        @id @default(autoincrement())
  ingredientId Int
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  date         DateTime
  menuName     String
  gramsUsed    Int
  mealType     String?
  createdAt    DateTime   @default(now())
}

model Recipe {
  id           Int         @id @default(autoincrement())
  name         String      @unique
  thumbnailUrl String?
  ingredients  Json
  steps        Json
  cookingTools Json        @default("[]")
  cookingTime  Int
  satisfaction Int
  calories     Int
  carbs        Float
  protein      Float
  fat          Float
  sodium       Float
  sugar        Float
  eatenDates   DateTime[]
  mealDiaries  MealDiary[]
  createdAt    DateTime    @default(now())
}

model MealDiary {
  id          Int      @id @default(autoincrement())
  date        DateTime
  mealType    String
  mealTime    String?
  photoUrl    String?
  diaryText   String?
  recipeId    Int?
  recipe      Recipe?  @relation(fields: [recipeId], references: [id])
  mealItems    Json     @default("[]")
  mealCategory String   @default("home-cooked")
  diningOutId  Int?
  createdAt    DateTime @default(now())
}

model NutritionInfo {
  id        Int    @id @default(autoincrement())
  name      String @unique
  calories  Int
  carbs     Float
  protein   Float
  fat       Float
  sodium    Float
  sugar     Float
}

model ShoppingList {
  id             Int      @id @default(autoincrement())
  name           String
  note           String?
  checked        Boolean  @default(false)
  autoGenerated  Boolean  @default(false)
  ingredientName String?
  remainingGrams Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NotificationPreference {
  id                           Int      @id @default(autoincrement())
  expiringIngredientsEnabled   Boolean  @default(true)
  mealDiaryReminderEnabled     Boolean  @default(true)
  browserNotificationsEnabled  Boolean  @default(true)
  reminderHour                 Int      @default(20)
  checkIntervalMinutes         Int      @default(30)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phoneLast String
  email     String   @unique
  createdAt DateTime @default(now())
}